---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"div"> {
  borderRadius?: string;
  magnetic?: boolean; // pulls towards cursor
  blendMode?: boolean;
}

const {
  borderRadius = "0px",
  magnetic = false,
  blendMode = true,
  class: className,
  ...rest
} = Astro.props;
---

<div
  class:list={["sticky-wrapper", className]}
  data-sticky
  data-magnetic={magnetic ? "true" : "false"}
  data-radius={borderRadius}
  data-blend={blendMode ? "true" : "false"}
  style={{ borderRadius: borderRadius }}
  {...rest}
>
  <slot />
</div>
<style>
  .sticky-wrapper {
    display: inline-flex;
    position: relative;
    box-sizing: border-box;
  }
</style>
