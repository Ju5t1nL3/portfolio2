---
import FallingText from "../components/ui/FallingText.astro";
import StickyWrapper from "./ui/StickyWrapper.astro";
---

<div class="flex h-svh w-svw items-center justify-center">
  <div class="flex flex-col items-center sm:hidden">
    <FallingText text="UNDER" class="text-2xl font-bold" />
    <FallingText text="CONSTRUCTION" class="mt-2 text-2xl font-bold" />
  </div>
  <div class="hidden sm:block">
    <FallingText text="UNDER CONSTRUCTION" class="text-4xl font-bold" />
  </div>
  <div class="animate-fade absolute bottom-30 z-50 text-xl opacity-0">
    <StickyWrapper blendMode={true} borderRadius="1rem">
      <a href="/sandbox" class="px-6 py-3 font-semibold">Sandbox</a>
    </StickyWrapper>
  </div>
</div>
<style>
  .animate-fade {
    animation: fadeIn 0.5s ease 2.5s forwards;
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }
</style>
